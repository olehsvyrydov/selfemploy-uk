<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    Help Page - SE-701: In-App Help System
    Design: /aura (Senior UI/UX Design Architect)
    Redesign: /finn - Minimal style to match Settings page

    Features:
    - Clean, minimal design matching Settings page
    - Simple section titles (no gradient headers)
    - settings-card-row style for help topics
    - Inline Quick Links at top
-->
<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="uk.selfemploy.ui.controller.HelpController"
            styleClass="help-scroll" fitToWidth="true" hbarPolicy="NEVER">

    <VBox styleClass="help-container" spacing="24">
        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

        <!-- Page Header -->
        <VBox spacing="8">
            <Label text="%help.title" styleClass="page-title"/>
            <Label text="%help.subtitle" styleClass="page-subtitle"/>
        </VBox>

        <!-- User Guide - Prominent section at top -->
        <VBox styleClass="help-section, help-section-guide" spacing="16">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="%help.userGuide.title" styleClass="section-title"/>
                <Button styleClass="user-guide-btn" onAction="#handleUserGuideClick" text="%help.userGuide.openFull"/>
                <Button fx:id="replayTourBtn" styleClass="user-guide-btn" onAction="#handleReplayTour" text="%help.userGuide.replayTour"/>
            </HBox>

            <!-- Getting Started -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleGettingStartedClick">
                <Label text="GS" styleClass="help-topic-badge, badge-violet"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.gettingStarted.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.gettingStarted.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- Bank Statement Import -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleBankImportClick">
                <Label text="BI" styleClass="help-topic-badge, badge-violet"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.bankImport.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.bankImport.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="&#x203A;" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- HMRC Connection -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleHmrcConnectionClick">
                <Label text="HC" styleClass="help-topic-badge, badge-violet"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.hmrcConnection.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.hmrcConnection.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- Security & Privacy -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleSecurityPrivacyClick">
                <Label text="SP" styleClass="help-topic-badge, badge-violet"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.securityPrivacy.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.securityPrivacy.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- FAQ -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleFaqClick">
                <Label text="?" styleClass="help-topic-badge, badge-violet"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.faq.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.faq.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>
        </VBox>

        <!-- Quick Links - Inline buttons at top -->
        <VBox styleClass="help-section" spacing="16">
            <Label text="%help.quickLinks.title" styleClass="section-title"/>
            <FlowPane hgap="12" vgap="12" styleClass="quick-links-flow">
                <Button styleClass="help-quick-link" onAction="#handleTaxRatesLink" text="%help.quickLinks.taxRates"/>
                <Button styleClass="help-quick-link" onAction="#handleSa103Link" text="%help.quickLinks.sa103Form"/>
                <Button styleClass="help-quick-link" onAction="#handleFilingDeadlinesLink" text="%help.quickLinks.deadlines"/>
                <Button styleClass="help-quick-link" onAction="#handleAllowableExpensesLink" text="%help.quickLinks.expenses"/>
                <Button styleClass="help-quick-link" onAction="#handleNiRatesLink" text="%help.quickLinks.niRates"/>
                <Button styleClass="help-quick-link" onAction="#handleStatePensionLink" text="%help.quickLinks.statePension"/>
            </FlowPane>
        </VBox>

        <!-- Tax & Calculation Section -->
        <VBox styleClass="help-section, help-section-tax" spacing="16">
            <Label text="%help.section.tax" styleClass="section-title"/>

            <!-- Net Profit -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleNetProfitClick">
                <Label text="NP" styleClass="help-topic-badge, badge-teal"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.netProfit.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.netProfit.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- Income Tax -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleIncomeTaxClick">
                <Label text="IT" styleClass="help-topic-badge, badge-teal"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.incomeTax.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.incomeTax.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- Personal Allowance -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handlePersonalAllowanceClick">
                <Label text="PA" styleClass="help-topic-badge, badge-teal"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.personalAllowance.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.personalAllowance.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- National Insurance Class 4 -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleNationalInsuranceClick">
                <Label text="N4" styleClass="help-topic-badge, badge-teal"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.niClass4.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.niClass4.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- National Insurance Class 2 -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleNationalInsuranceClass2Click">
                <Label text="N2" styleClass="help-topic-badge, badge-teal"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.niClass2.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.niClass2.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- Payments on Account -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handlePaymentsOnAccountClick">
                <Label text="PoA" styleClass="help-topic-badge, badge-teal"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.paymentsOnAccount.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.paymentsOnAccount.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>
        </VBox>

        <!-- Expenses Section -->
        <VBox styleClass="help-section, help-section-expenses" spacing="16">
            <Label text="%help.section.expenses" styleClass="section-title"/>

            <!-- Expense Categories -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleExpenseCategoriesClick">
                <Label text="EC" styleClass="help-topic-badge, badge-amber"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.expenseCategories.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.expenseCategories.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- Allowable Expenses -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleAllowableExpensesClick">
                <Label text="AE" styleClass="help-topic-badge, badge-amber"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.allowableExpenses.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.allowableExpenses.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>
        </VBox>

        <!-- HMRC Submission Section -->
        <VBox styleClass="help-section, help-section-hmrc" spacing="16">
            <Label text="%help.section.hmrcSubmission" styleClass="section-title"/>

            <!-- Declaration -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleDeclarationClick">
                <Label text="D" styleClass="help-topic-badge, badge-sky"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.declaration.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.declaration.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- Submitting to HMRC -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleHmrcSubmissionClick">
                <Label text="S" styleClass="help-topic-badge, badge-sky"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.submittingToHmrc.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.submittingToHmrc.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>
        </VBox>

        <!-- General Section -->
        <VBox styleClass="help-section, help-section-general" spacing="16">
            <Label text="%help.section.general" styleClass="section-title"/>

            <!-- Tax Year -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleTaxYearClick">
                <Label text="TY" styleClass="help-topic-badge, badge-slate"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.taxYear.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.taxYear.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>

            <!-- SA103 Form -->
            <HBox styleClass="help-topic-row" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleSa103FormClick">
                <Label text="103" styleClass="help-topic-badge, badge-slate"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%help.topic.sa103Form.title" styleClass="help-topic-title"/>
                    <Label text="%help.topic.sa103Form.desc" styleClass="help-topic-desc"/>
                </VBox>
                <Label text="›" styleClass="help-topic-chevron"/>
            </HBox>
        </VBox>

        <!-- Need More Help Section (Consolidated) -->
        <VBox styleClass="help-section, help-section-support" spacing="16">
            <Label text="%help.section.needMoreHelp" styleClass="section-title"/>

            <VBox styleClass="help-support-card" spacing="12">
                <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                <Label text="%help.support.text"
                       styleClass="help-support-text" wrapText="true"/>
                <HBox spacing="12">
                    <Button styleClass="help-quick-link" onAction="#handleGitHubIssuesLink" text="%help.support.githubIssues"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- About Section -->
        <VBox styleClass="help-section, help-section-about" spacing="16">
            <Label text="%help.section.about" styleClass="section-title"/>

            <VBox styleClass="help-about-card" spacing="12">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <!-- App Identity -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="SE" styleClass="about-logo"/>
                    <VBox spacing="4">
                        <Label text="%help.about.appName" styleClass="about-app-name"/>
                        <Label fx:id="versionLabel" text="%help.about.version" styleClass="about-version"/>
                    </VBox>
                </HBox>

                <!-- Description -->
                <Label text="%help.about.description"
                       styleClass="about-description" wrapText="true"/>

                <!-- Links -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Hyperlink text="%help.about.viewGitHub" styleClass="about-link" onAction="#handleViewGitHubLink"/>
                </HBox>

                <!-- License -->
                <Label text="%help.about.license" styleClass="about-license"/>
            </VBox>
        </VBox>

        <!-- Footer disclaimer removed per SLFEMPUK-19: Legal section covers this -->

    </VBox>
</ScrollPane>
