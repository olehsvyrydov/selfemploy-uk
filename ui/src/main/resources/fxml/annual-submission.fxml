<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<!--
  Annual Self Assessment Submission View - SE-403

  Responsive layout (T1.8):
  - Header and step indicator are pinned at the top (always visible).
  - The middle content scrolls vertically and fits the width (no horizontal scroll).
  - The action bar is pinned at the bottom so the primary action is always in view.
-->

<!-- Stylesheets loaded programmatically to avoid JPMS issues -->
<BorderPane fx:id="rootPane" styleClass="annual-container" xmlns:fx="http://javafx.com/fxml"
            fx:controller="uk.selfemploy.ui.controller.AnnualSubmissionController">

    <!-- Pinned header + step indicator -->
    <top>
        <VBox styleClass="annual-header-region" spacing="24">
            <padding>
                <Insets top="24" right="24" bottom="12" left="24"/>
            </padding>

            <!-- Header -->
            <VBox spacing="8">
                <Label text="%annual.page.title" styleClass="page-title"/>
                <Label fx:id="taxYearLabel" text="Tax Year 2025/26" styleClass="page-subtitle"/>
            </VBox>

            <!-- Progress Indicator - always visible -->
            <HBox fx:id="progressIndicator" styleClass="progress-indicator" spacing="0" alignment="CENTER">
                <!-- Step 1 - Active by default -->
                <VBox fx:id="step1Container" styleClass="step-container, step-active" alignment="CENTER" minWidth="120">
                    <HBox styleClass="step-header" alignment="CENTER">
                        <Label fx:id="step1Number" text="1" styleClass="step-number"/>
                    </HBox>
                    <Label text="%annual.step.reviewSummary" styleClass="step-label" textAlignment="CENTER"/>
                </VBox>

                <!-- Connector 1-2 -->
                <Region styleClass="step-connector" HBox.hgrow="ALWAYS" minWidth="40" maxWidth="80"/>

                <!-- Step 2 -->
                <VBox fx:id="step2Container" styleClass="step-container" alignment="CENTER" minWidth="120">
                    <HBox styleClass="step-header" alignment="CENTER">
                        <Label fx:id="step2Number" text="2" styleClass="step-number"/>
                    </HBox>
                    <Label text="%annual.step.calculateTax" styleClass="step-label" textAlignment="CENTER"/>
                </VBox>

                <!-- Connector 2-3 -->
                <Region styleClass="step-connector" HBox.hgrow="ALWAYS" minWidth="40" maxWidth="80"/>

                <!-- Step 3 -->
                <VBox fx:id="step3Container" styleClass="step-container" alignment="CENTER" minWidth="120">
                    <HBox styleClass="step-header" alignment="CENTER">
                        <Label fx:id="step3Number" text="3" styleClass="step-number"/>
                    </HBox>
                    <Label text="%annual.step.review" styleClass="step-label" textAlignment="CENTER"/>
                </VBox>

                <!-- Connector 3-4 -->
                <Region styleClass="step-connector" HBox.hgrow="ALWAYS" minWidth="40" maxWidth="80"/>

                <!-- Step 4 -->
                <VBox fx:id="step4Container" styleClass="step-container" alignment="CENTER" minWidth="120">
                    <HBox styleClass="step-header" alignment="CENTER">
                        <Label fx:id="step4Number" text="4" styleClass="step-number"/>
                    </HBox>
                    <Label text="%annual.step.submit" styleClass="step-label" textAlignment="CENTER"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- Scrollable content: fits width so there is never a horizontal scrollbar -->
    <center>
        <ScrollPane fx:id="rootScroll" styleClass="annual-scroll" fitToWidth="true"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox styleClass="annual-content" spacing="24">
                <padding>
                    <Insets top="12" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Main Content Area -->
                <HBox spacing="24">
                    <!-- Left Panel: Summary -->
                    <VBox fx:id="summaryPanel" styleClass="summary-panel" spacing="16" HBox.hgrow="ALWAYS">
                        <Label text="%annual.summary.title" styleClass="panel-title"/>

                        <!-- Income Section -->
                        <VBox spacing="8" styleClass="summary-section">
                            <Label text="%annual.summary.income" styleClass="section-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="%annual.summary.turnover" styleClass="item-label" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="turnoverValue" text="£0.00" styleClass="item-value"/>
                            </HBox>
                        </VBox>

                        <!-- Expenses Section -->
                        <VBox spacing="8" styleClass="summary-section">
                            <Label text="%annual.summary.expenses" styleClass="section-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="%annual.summary.allowableExpenses" styleClass="item-label" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="expensesValue" text="£0.00" styleClass="item-value expense"/>
                            </HBox>
                        </VBox>

                        <!-- Separator -->
                        <Separator/>

                        <!-- Net Profit -->
                        <VBox spacing="8">
                            <Label text="%annual.summary.netProfitLabel" styleClass="section-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="%annual.summary.netProfit" styleClass="item-label-bold" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="netProfitValue" text="£0.00" styleClass="item-value-large profit"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Right Panel: Calculation (visible from Step 2) -->
                    <VBox fx:id="calculationPanel" styleClass="calculation-panel" spacing="16" HBox.hgrow="ALWAYS" visible="false" managed="false">
                        <Label text="%annual.calc.title" styleClass="panel-title"/>

                        <!-- Loading Indicator -->
                        <VBox fx:id="loadingIndicator" styleClass="loading-container" alignment="CENTER" spacing="12" visible="false" managed="false">
                            <ProgressIndicator/>
                            <Label text="%annual.calc.loading" styleClass="loading-text"/>
                        </VBox>

                        <!-- Calculation Results -->
                        <VBox fx:id="calculationResults" spacing="12" visible="false" managed="false">
                            <!-- Income Tax -->
                            <VBox spacing="8" styleClass="summary-section">
                                <Label text="%annual.calc.incomeTax" styleClass="section-label"/>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="%annual.calc.totalIncomeTax" styleClass="item-label" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="incomeTaxValue" text="£0.00" styleClass="item-value tax"/>
                                </HBox>
                            </VBox>

                            <!-- National Insurance -->
                            <VBox spacing="8" styleClass="summary-section">
                                <Label text="%annual.calc.nationalInsurance" styleClass="section-label"/>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="%annual.calc.totalNi" styleClass="item-label" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="niValue" text="£0.00" styleClass="item-value tax"/>
                                </HBox>
                            </VBox>

                            <!-- Separator -->
                            <Separator/>

                            <!-- Total Due -->
                            <VBox spacing="8">
                                <Label text="%annual.calc.totalLiability" styleClass="section-label"/>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="%annual.calc.totalTaxDue" styleClass="item-label-bold" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="totalTaxValue" text="£0.00" styleClass="item-value-large tax"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- Error Panel -->
                <VBox fx:id="errorPanel" styleClass="error-panel" spacing="8" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="⚠" styleClass="error-icon"/>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="%annual.error.title" styleClass="error-title"/>
                            <Label fx:id="errorMessage" text="" styleClass="error-text" wrapText="true"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="12">
                        <Button fx:id="retryButton" text="%annual.button.retry" styleClass="button-warning" onAction="#handleRetry"/>
                        <Button text="%annual.button.cancel" styleClass="button-secondary" onAction="#handleCancel"/>
                    </HBox>
                </VBox>

                <!-- Success Panel -->
                <VBox fx:id="successPanel" styleClass="success-panel" spacing="12" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="✓" styleClass="success-icon"/>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="%annual.success.title" styleClass="success-title"/>
                            <Label text="%annual.success.text" styleClass="success-text" wrapText="true"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="%annual.success.reference" styleClass="field-label"/>
                        <Label fx:id="submissionReference" text="" styleClass="reference-text"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button fx:id="doneButton" text="%annual.button.done" styleClass="button-primary" onAction="#handleDone"/>
                    </HBox>
                </VBox>

                <!-- HMRC Submission Disclaimer (SE-509, AC-2) -->
                <!-- IMPORTANT: This disclaimer cannot be dismissed (AC-4) -->
                <HBox fx:id="submissionDisclaimerBanner" styleClass="submission-disclaimer, disclaimer-persistent"
                      alignment="TOP_LEFT" spacing="12" visible="false" managed="false">
                    <Label text="i" styleClass="submission-disclaimer-icon"/>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="%annual.disclaimer.title" styleClass="submission-disclaimer-title"/>
                        <Label fx:id="submissionDisclaimerText"
                               text="%annual.disclaimer.text"
                               styleClass="submission-disclaimer-text" wrapText="true"/>
                    </VBox>
                </HBox>

                <!-- 6-Checkbox Declaration Card (SE-512) -->
                <VBox fx:id="declarationCard" styleClass="declaration-card-6box" spacing="12" visible="false" managed="false">

                    <!-- Header -->
                    <HBox styleClass="declaration-header" alignment="CENTER_LEFT" spacing="12">
                        <Label text="!" styleClass="declaration-warning-icon"/>
                        <Label text="%annual.declaration.title" styleClass="declaration-title"/>
                    </HBox>

                    <Label text="%annual.declaration.instruction" styleClass="declaration-instruction" wrapText="true"/>

                    <!-- Declaration Rows Container -->
                    <VBox fx:id="declarationRows" spacing="12">

                        <!-- Row 1: Accuracy Statement (HMRC Official) -->
                        <HBox fx:id="decl1Row" styleClass="declaration-row, hmrc-official" alignment="TOP_LEFT" spacing="16">
                            <CheckBox fx:id="decl1Checkbox" styleClass="declaration-checkbox"
                                      onAction="#handleDeclarationChange"/>
                            <Label fx:id="decl1Text" text="%annual.declaration.row1" styleClass="declaration-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Row 2: Penalties Warning (HMRC Official) -->
                        <HBox fx:id="decl2Row" styleClass="declaration-row, hmrc-official" alignment="TOP_LEFT" spacing="16">
                            <CheckBox fx:id="decl2Checkbox" styleClass="declaration-checkbox"
                                      onAction="#handleDeclarationChange"/>
                            <Label fx:id="decl2Text" text="%annual.declaration.row2" styleClass="declaration-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Row 3: Record Keeping -->
                        <HBox fx:id="decl3Row" styleClass="declaration-row" alignment="TOP_LEFT" spacing="16">
                            <CheckBox fx:id="decl3Checkbox" styleClass="declaration-checkbox"
                                      onAction="#handleDeclarationChange"/>
                            <Label fx:id="decl3Text" text="%annual.declaration.row3" styleClass="declaration-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Row 4: Calculation Verification -->
                        <HBox fx:id="decl4Row" styleClass="declaration-row" alignment="TOP_LEFT" spacing="16">
                            <CheckBox fx:id="decl4Checkbox" styleClass="declaration-checkbox"
                                      onAction="#handleDeclarationChange"/>
                            <Label fx:id="decl4Text" text="%annual.declaration.row4" styleClass="declaration-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Row 5: Legal Effect -->
                        <HBox fx:id="decl5Row" styleClass="declaration-row" alignment="TOP_LEFT" spacing="16">
                            <CheckBox fx:id="decl5Checkbox" styleClass="declaration-checkbox"
                                      onAction="#handleDeclarationChange"/>
                            <Label fx:id="decl5Text" text="%annual.declaration.row5" styleClass="declaration-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Row 6: Identity Confirmation -->
                        <HBox fx:id="decl6Row" styleClass="declaration-row" alignment="TOP_LEFT" spacing="16">
                            <CheckBox fx:id="decl6Checkbox" styleClass="declaration-checkbox"
                                      onAction="#handleDeclarationChange"/>
                            <Label fx:id="decl6Text" text="%annual.declaration.row6" styleClass="declaration-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                        </HBox>

                    </VBox>

                    <!-- Progress Counter -->
                    <HBox fx:id="progressSection" styleClass="declaration-progress" alignment="CENTER">
                        <Label fx:id="progressLabel" text="0 of 6 confirmations completed"
                               styleClass="declaration-progress-text"/>
                    </HBox>

                    <!-- Timestamp Section (hidden initially) -->
                    <VBox fx:id="timestampSection" styleClass="declaration-timestamp-section"
                          managed="false" visible="false" spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="✓" styleClass="declaration-timestamp-icon"/>
                            <Label text="%annual.timestamp.title" styleClass="declaration-timestamp-title"/>
                        </HBox>
                        <Label fx:id="timestampLabel" text="" styleClass="declaration-timestamp-details" wrapText="true"/>
                        <Label fx:id="declarationIdLabel" text="" styleClass="declaration-timestamp-details" wrapText="true"/>
                        <Label text="%annual.timestamp.note"
                               styleClass="declaration-timestamp-note" wrapText="true"/>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- Pinned action bar: the primary action is always inside the viewport -->
    <bottom>
        <HBox fx:id="actionBar" styleClass="action-bar" spacing="12" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="12" right="24" bottom="16" left="24"/>
            </padding>
            <Button fx:id="cancelButton" text="%annual.button.cancel" styleClass="button-secondary" onAction="#handleCancel"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="calculateButton" text="%annual.button.calculate" styleClass="button-primary" onAction="#handleCalculate" visible="true" managed="true"/>
            <Button fx:id="reviewButton" text="%annual.button.review" styleClass="button-primary" onAction="#handleReview" visible="false" managed="false"/>
            <!-- Submit Button with Declaration Binding (SE-506) -->
            <VBox alignment="CENTER_RIGHT" spacing="4" visible="false" managed="false" fx:id="submitContainer">
                <Button fx:id="submitButton" text="%annual.button.submit" styleClass="button-primary, button-submit-hmrc"
                        onAction="#handleSubmit" disable="true"/>
                <!-- Helper Text (AC-3) -->
                <Label fx:id="submitHelperText" text="%annual.submit.helper"
                       styleClass="submit-helper-text"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>
