<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="uk.selfemploy.ui.controller.AppUnlockController"
           styleClass="onboarding-container" prefWidth="520" prefHeight="480">
    <VBox fx:id="card" styleClass="onboarding-card" alignment="CENTER" spacing="16"
          maxWidth="420" StackPane.alignment="CENTER">
        <StackPane styleClass="onboarding-icon-circle" minWidth="56" minHeight="56"
                   maxWidth="56" maxHeight="56">
            <FontIcon iconLiteral="fas-lock" iconSize="24" styleClass="onboarding-icon"/>
        </StackPane>

        <Label fx:id="titleLabel" text="%unlock.title" styleClass="onboarding-title"/>
        <Label fx:id="subtitleLabel" text="%unlock.subtitle" styleClass="onboarding-subtitle"
               wrapText="true"/>

        <VBox styleClass="form-field" spacing="6" maxWidth="340">
            <PasswordField fx:id="secretField" styleClass="form-input"
                           promptText="%unlock.passphrase.prompt"
                           onAction="#handleUnlock"/>
            <Label fx:id="errorLabel" styleClass="field-error" wrapText="true"
                   visible="false" managed="false"/>
        </VBox>

        <Button fx:id="unlockButton" text="%unlock.button" styleClass="button-primary, button-large"
                maxWidth="340" onAction="#handleUnlock"/>

        <Hyperlink fx:id="recoveryLink" text="%unlock.useRecovery" onAction="#handleToggleRecovery"/>
    </VBox>
</StackPane>
