<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Stylesheets loaded programmatically to avoid JPMS issues -->
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="uk.selfemploy.ui.controller.BankImportWizardController"
      styleClass="wizard-container" spacing="0" prefWidth="1000">

    <!-- Fixed Header -->
    <VBox spacing="24" styleClass="wizard-header-section">
        <padding><Insets top="30" right="30" bottom="0" left="30"/></padding>

        <!-- Wizard Header -->
        <VBox spacing="8">
            <Label text="%bankImport.title" styleClass="page-title"/>
            <Label text="%bankImport.subtitle"
                   styleClass="page-subtitle"/>
        </VBox>

        <!-- Progress Indicator -->
        <HBox fx:id="progressIndicator" styleClass="wizard-progress" alignment="CENTER" spacing="0">
        <VBox fx:id="step1Circle" styleClass="progress-step, step-active" alignment="CENTER" spacing="4">
            <StackPane styleClass="step-circle">
                <Label text="1" styleClass="step-number"/>
            </StackPane>
            <Label text="%bankImport.step1.label" styleClass="step-label"/>
        </VBox>
        <HBox styleClass="step-connector"/>
        <VBox fx:id="step2Circle" styleClass="progress-step" alignment="CENTER" spacing="4">
            <StackPane styleClass="step-circle">
                <Label text="2" styleClass="step-number"/>
            </StackPane>
            <Label text="%bankImport.step2.label" styleClass="step-label"/>
        </VBox>
        <HBox styleClass="step-connector"/>
        <VBox fx:id="step3Circle" styleClass="progress-step" alignment="CENTER" spacing="4">
            <StackPane styleClass="step-circle">
                <Label text="3" styleClass="step-number"/>
            </StackPane>
            <Label text="%bankImport.step3.label" styleClass="step-label"/>
        </VBox>
        <HBox styleClass="step-connector"/>
        <VBox fx:id="step4Circle" styleClass="progress-step" alignment="CENTER" spacing="4">
            <StackPane styleClass="step-circle">
                <Label text="4" styleClass="step-number"/>
            </StackPane>
            <Label text="%bankImport.step4.label" styleClass="step-label"/>
        </VBox>
    </HBox>
    </VBox>

    <!-- Scrollable Content Area -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                styleClass="wizard-scroll-pane">
    <VBox spacing="0">
    <padding><Insets top="24" right="30" bottom="24" left="30"/></padding>

    <!-- Step 1 Content: File Selection -->
    <VBox fx:id="step1Content" styleClass="wizard-content" spacing="20" VBox.vgrow="ALWAYS">

        <!-- Drag & Drop Zone -->
        <VBox fx:id="dropZone" styleClass="drop-zone" alignment="CENTER" spacing="16"
              onDragOver="#handleDragOver" onDragDropped="#handleDragDropped"
              onDragExited="#handleDragExited">
            <StackPane styleClass="drop-zone-icon">
                <FontIcon iconLiteral="fas-file-csv" iconSize="48" styleClass="drop-zone-glyph"/>
            </StackPane>
            <VBox alignment="CENTER" spacing="8">
                <Label text="%bankImport.dropZone.title" styleClass="drop-zone-title"/>
                <Label text="%bankImport.dropZone.separator" styleClass="drop-zone-separator"/>
                <Button fx:id="browseBtn" text="%bankImport.button.browse" styleClass="button-secondary"
                        onAction="#handleBrowseFiles"/>
            </VBox>
            <Label text="%bankImport.dropZone.hint"
                   styleClass="drop-zone-hint"/>
        </VBox>

        <!-- File Selected State (hidden initially) -->
        <VBox fx:id="fileSelectedBox" styleClass="file-selected-box" spacing="12"
              managed="false" visible="false">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="file-icon">
                    <FontIcon iconLiteral="fas-file-csv" iconSize="20" styleClass="file-glyph"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="fileNameLabel" text="bank-statement.csv"
                           styleClass="file-name"/>
                    <Label fx:id="fileSizeLabel" text="245 KB - 142 rows detected"
                           styleClass="file-meta"/>
                </VBox>
                <Button fx:id="changeFileBtn" text="%bankImport.button.change" styleClass="button-link"
                        onAction="#handleChangeFile"/>
            </HBox>

            <!-- Bank Format Detection -->
            <HBox fx:id="bankDetectedBox" styleClass="bank-detected-box"
                  alignment="CENTER_LEFT" spacing="12" managed="false" visible="false">
                <FontIcon iconLiteral="fas-check-circle" iconSize="16" styleClass="detection-icon"/>
                <VBox spacing="2">
                    <Label fx:id="bankNameLabel" text="Barclays format detected"
                           styleClass="detection-title"/>
                    <Label text="%bankImport.detection.hint"
                           styleClass="detection-hint"/>
                </VBox>
            </HBox>

            <!-- Unknown Format Warning -->
            <HBox fx:id="unknownFormatBox" styleClass="unknown-format-box"
                  alignment="CENTER_LEFT" spacing="12" managed="false" visible="false">
                <FontIcon iconLiteral="fas-question-circle" iconSize="16" styleClass="warning-icon"/>
                <VBox spacing="2">
                    <Label text="%bankImport.unknownFormat.title" styleClass="warning-title"/>
                    <Label text="%bankImport.unknownFormat.hint"
                           styleClass="warning-hint"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Supported Banks Info -->
        <VBox styleClass="supported-banks" spacing="8">
            <Label text="%bankImport.supportedBanks.label" styleClass="info-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Barclays" styleClass="bank-chip"/>
                <Label text="HSBC" styleClass="bank-chip"/>
                <Label text="Lloyds" styleClass="bank-chip"/>
                <Label text="Nationwide" styleClass="bank-chip"/>
                <Label text="Starling" styleClass="bank-chip"/>
                <Label text="Monzo" styleClass="bank-chip"/>
            </HBox>
        </VBox>

    </VBox>

    <!-- Step 2 Content: Column Mapping -->
    <VBox fx:id="step2Content" styleClass="wizard-content" spacing="20"
          managed="false" visible="false" VBox.vgrow="ALWAYS">

        <!-- Instructions -->
        <HBox styleClass="info-banner" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="info-banner-icon">
                <FontIcon iconLiteral="fas-info-circle" iconSize="16" styleClass="info-banner-glyph"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="%bankImport.step2.instruction.title"
                       styleClass="info-banner-title"/>
                <Label text="%bankImport.step2.instruction.text"
                       styleClass="info-banner-text"/>
            </VBox>
        </HBox>

        <!-- Preview of CSV Headers -->
        <VBox styleClass="csv-preview-box" spacing="8">
            <Label text="%bankImport.csvColumns.label" styleClass="section-label"/>
            <HBox fx:id="csvHeadersPreview" styleClass="csv-headers" spacing="8">
                <!-- Populated dynamically with column chips -->
            </HBox>
        </VBox>

        <!-- Column Mapping Form -->
        <VBox styleClass="mapping-form" spacing="16">
            <Label text="%bankImport.fieldMapping.label" styleClass="section-label"/>

            <!-- Date Mapping -->
            <HBox styleClass="mapping-row" alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" minWidth="200">
                    <HBox alignment="CENTER_LEFT" spacing="4">
                        <Label text="%bankImport.field.date" styleClass="field-label"/>
                        <Label text="*" styleClass="required-indicator"/>
                    </HBox>
                    <Label text="%bankImport.field.date.hint" styleClass="field-hint"/>
                </VBox>
                <ComboBox fx:id="dateColumnCombo" styleClass="mapping-combo"
                          promptText="%bankImport.prompt.selectColumn" prefWidth="250"/>
                <VBox fx:id="dateFormatBox" spacing="4" managed="false" visible="false">
                    <Label text="%bankImport.field.dateFormat" styleClass="field-hint"/>
                    <ComboBox fx:id="dateFormatCombo" styleClass="mapping-combo-small"
                              prefWidth="150"/>
                </VBox>
            </HBox>

            <!-- Description Mapping -->
            <HBox styleClass="mapping-row" alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" minWidth="200">
                    <HBox alignment="CENTER_LEFT" spacing="4">
                        <Label text="%bankImport.field.description" styleClass="field-label"/>
                        <Label text="*" styleClass="required-indicator"/>
                    </HBox>
                    <Label text="%bankImport.field.description.hint" styleClass="field-hint"/>
                </VBox>
                <ComboBox fx:id="descriptionColumnCombo" styleClass="mapping-combo"
                          promptText="%bankImport.prompt.selectColumn" prefWidth="250"/>
            </HBox>

            <!-- Amount Mapping -->
            <HBox styleClass="mapping-row" alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" minWidth="200">
                    <HBox alignment="CENTER_LEFT" spacing="4">
                        <Label text="%bankImport.field.amount" styleClass="field-label"/>
                        <Label text="*" styleClass="required-indicator"/>
                    </HBox>
                    <Label text="%bankImport.field.amount.hint" styleClass="field-hint"/>
                </VBox>
                <ComboBox fx:id="amountColumnCombo" styleClass="mapping-combo"
                          promptText="%bankImport.prompt.selectColumn" prefWidth="250"/>
                <CheckBox fx:id="separateColumnsCheckbox"
                          text="%bankImport.separateColumns.checkbox"/>
            </HBox>

            <!-- Separate Columns (conditional) -->
            <VBox fx:id="separateColumnsBox" styleClass="nested-mapping" spacing="12"
                  managed="false" visible="false">
                <HBox styleClass="mapping-row" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" minWidth="200">
                        <Label text="%bankImport.field.incomeColumn" styleClass="field-label"/>
                        <Label text="%bankImport.field.incomeColumn.hint" styleClass="field-hint"/>
                    </VBox>
                    <ComboBox fx:id="incomeColumnCombo" styleClass="mapping-combo"
                              promptText="%bankImport.prompt.selectColumn" prefWidth="250"/>
                </HBox>
                <HBox styleClass="mapping-row" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" minWidth="200">
                        <Label text="%bankImport.field.expenseColumn" styleClass="field-label"/>
                        <Label text="%bankImport.field.expenseColumn.hint" styleClass="field-hint"/>
                    </VBox>
                    <ComboBox fx:id="expenseColumnCombo" styleClass="mapping-combo"
                              promptText="%bankImport.prompt.selectColumn" prefWidth="250"/>
                </HBox>
            </VBox>

            <!-- Category Mapping (Optional) -->
            <HBox styleClass="mapping-row" alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" minWidth="200">
                    <HBox alignment="CENTER_LEFT" spacing="4">
                        <Label text="%bankImport.field.category" styleClass="field-label"/>
                        <Label text="%bankImport.optional" styleClass="optional-indicator"/>
                    </HBox>
                    <Label text="%bankImport.field.category.hint" styleClass="field-hint"/>
                </VBox>
                <ComboBox fx:id="categoryColumnCombo" styleClass="mapping-combo"
                          promptText="%bankImport.prompt.noneAutoCategorize" prefWidth="250"/>
            </HBox>
        </VBox>

        <!-- Sample Preview -->
        <VBox styleClass="sample-preview" spacing="8">
            <Label text="%bankImport.samplePreview.label" styleClass="section-label"/>
            <TableView fx:id="samplePreviewTable" styleClass="preview-table"
                       prefHeight="150" maxHeight="150">
                <!-- Shows first 3 rows with mapped columns -->
            </TableView>
        </VBox>

    </VBox>

    <!-- Step 3 Content: Preview & Categorize -->
    <VBox fx:id="step3Content" styleClass="wizard-content" spacing="20"
          managed="false" visible="false" VBox.vgrow="ALWAYS">

        <!-- Summary Stats -->
        <HBox styleClass="import-stats" spacing="24" alignment="CENTER_LEFT">
            <VBox styleClass="stat-box, stat-income" alignment="CENTER" spacing="4">
                <Label fx:id="incomeCountLabel" text="0" styleClass="stat-value"/>
                <Label text="%bankImport.income" styleClass="stat-label"/>
                <Label fx:id="incomeTotalLabel" text="£0.00" styleClass="stat-amount"/>
            </VBox>
            <VBox styleClass="stat-box, stat-expense" alignment="CENTER" spacing="4">
                <Label fx:id="expenseCountLabel" text="0" styleClass="stat-value"/>
                <Label text="%bankImport.expenses" styleClass="stat-label"/>
                <Label fx:id="expenseTotalLabel" text="£0.00" styleClass="stat-amount"/>
            </VBox>
            <VBox styleClass="stat-box, stat-duplicate" alignment="CENTER" spacing="4">
                <Label fx:id="duplicateCountLabel" text="0" styleClass="stat-value"/>
                <Label text="%bankImport.stat.duplicates" styleClass="stat-label"/>
                <Label text="%bankImport.stat.willBeSkipped" styleClass="stat-hint"/>
            </VBox>
            <VBox styleClass="stat-box, stat-uncategorized" alignment="CENTER" spacing="4">
                <Label fx:id="uncategorizedCountLabel" text="0" styleClass="stat-value"/>
                <Label text="%bankImport.stat.needCategory" styleClass="stat-label"/>
                <Label text="%bankImport.stat.assignBelow" styleClass="stat-hint"/>
            </VBox>
        </HBox>

        <!-- Duplicate Warning (conditional) -->
        <HBox fx:id="duplicateWarning" styleClass="warning-banner"
              alignment="CENTER_LEFT" spacing="12" managed="false" visible="false">
            <FontIcon iconLiteral="fas-exclamation-triangle" iconSize="16" styleClass="warning-banner-icon"/>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="duplicateWarningTitle" text="3 potential duplicates found"
                       styleClass="warning-banner-title"/>
                <Label text="%bankImport.duplicateWarning.text"
                       styleClass="warning-banner-text"/>
            </VBox>
            <Button text="%bankImport.button.review" styleClass="button-link" onAction="#handleReviewDuplicates"/>
        </HBox>

        <!-- Filter/Actions Bar -->
        <HBox styleClass="preview-actions" alignment="CENTER_LEFT" spacing="12">
            <ComboBox fx:id="filterCombo" styleClass="filter-combo" prefWidth="180"/>
            <TextField fx:id="searchField" styleClass="search-field"
                       promptText="%bankImport.prompt.searchTransactions" prefWidth="250"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="bulkCategoryBtn" text="%bankImport.button.bulkCategory"
                    styleClass="button-secondary" onAction="#handleBulkCategory" disable="true"/>
        </HBox>

        <!-- Transactions Table -->
        <TableView fx:id="transactionsTable" styleClass="import-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="selectColumn" prefWidth="40" sortable="false"/>
                <TableColumn fx:id="statusColumn" text="" prefWidth="50" sortable="false"/>
                <TableColumn fx:id="dateColumn" text="%bankImport.field.date" prefWidth="100"/>
                <TableColumn fx:id="descriptionColumn" text="%bankImport.field.description" prefWidth="300"/>
                <TableColumn fx:id="amountColumn" text="%bankImport.field.amount" prefWidth="120"/>
                <TableColumn fx:id="typeColumn" text="%bankImport.column.type" prefWidth="80"/>
                <TableColumn fx:id="categoryColumn" text="%bankImport.field.category" prefWidth="180"/>
                <TableColumn fx:id="confidenceColumn" text="%bankImport.column.confidence" prefWidth="100"/>
            </columns>
            <placeholder>
                <Label text="%bankImport.table.empty" styleClass="empty-table-message"/>
            </placeholder>
        </TableView>

        <!-- Category Suggestion Panel (shows on row selection) -->
        <HBox fx:id="suggestionPanel" styleClass="suggestion-panel"
              alignment="CENTER_LEFT" spacing="12" managed="false" visible="false">
            <FontIcon iconLiteral="fas-lightbulb" iconSize="16" styleClass="suggestion-icon"/>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="suggestionText" text="Suggested: Office Supplies (85% confidence)"
                       styleClass="suggestion-title"/>
                <Label fx:id="suggestionReason" text="Based on description containing 'Staples'"
                       styleClass="suggestion-reason"/>
            </VBox>
            <Button fx:id="acceptSuggestionBtn" text="%bankImport.button.accept" styleClass="button-success-small"
                    onAction="#handleAcceptSuggestion"/>
            <Button fx:id="rejectSuggestionBtn" text="%bankImport.button.different" styleClass="button-secondary-small"
                    onAction="#handleRejectSuggestion"/>
        </HBox>

    </VBox>

    <!-- Step 4 Content: Confirm & Import -->
    <VBox fx:id="step4Content" styleClass="wizard-content" spacing="24"
          managed="false" visible="false" VBox.vgrow="ALWAYS">

        <!-- Success Pre-check -->
        <VBox styleClass="confirm-header" alignment="CENTER" spacing="16">
            <StackPane styleClass="confirm-icon">
                <FontIcon iconLiteral="fas-check-circle" iconSize="48" styleClass="confirm-glyph"/>
            </StackPane>
            <Label text="%bankImport.confirm.title" styleClass="confirm-title"/>
            <Label text="%bankImport.confirm.subtitle"
                   styleClass="confirm-subtitle"/>
        </VBox>

        <!-- Import Summary Card -->
        <VBox styleClass="summary-card" spacing="16">
            <Label text="%bankImport.summary.label" styleClass="section-label"/>

            <HBox spacing="24">
                <!-- Income Summary -->
                <VBox styleClass="summary-section" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="%bankImport.income" styleClass="summary-section-title"/>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="%bankImport.summary.transactions" styleClass="summary-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="confirmIncomeCount" text="0" styleClass="summary-value"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="%bankImport.summary.totalAmount" styleClass="summary-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="confirmIncomeTotal" text="£0.00"
                               styleClass="summary-value, income"/>
                    </HBox>
                </VBox>

                <Separator orientation="VERTICAL"/>

                <!-- Expense Summary -->
                <VBox styleClass="summary-section" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="%bankImport.expenses" styleClass="summary-section-title"/>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="%bankImport.summary.transactions" styleClass="summary-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="confirmExpenseCount" text="0" styleClass="summary-value"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="%bankImport.summary.totalAmount" styleClass="summary-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="confirmExpenseTotal" text="£0.00"
                               styleClass="summary-value, expense"/>
                    </HBox>
                </VBox>
            </HBox>

            <Separator/>

            <!-- Category Breakdown -->
            <VBox spacing="8">
                <Label text="%bankImport.summary.expenseCategories" styleClass="summary-section-title"/>
                <VBox fx:id="categoryBreakdown" styleClass="category-breakdown" spacing="4">
                    <!-- Populated dynamically -->
                </VBox>
            </VBox>

            <Separator/>

            <!-- Skipped Items -->
            <HBox fx:id="skippedSection" alignment="CENTER_LEFT" spacing="8">
                <FontIcon iconLiteral="fas-info-circle" iconSize="16" styleClass="info-icon"/>
                <Label fx:id="skippedLabel" text="0 duplicate transactions will be skipped"
                       styleClass="info-text"/>
            </HBox>

        </VBox>

        <!-- Data Source Label -->
        <HBox styleClass="source-info" alignment="CENTER_LEFT" spacing="8">
            <Label text="%bankImport.source.label" styleClass="info-label"/>
            <Label fx:id="sourceFileLabel" text="" styleClass="source-value"/>
            <Label text="%bankImport.source.hint"
                   styleClass="source-hint"/>
        </HBox>

        <!-- Import Button -->
        <HBox alignment="CENTER" spacing="16">
            <Button fx:id="importBtn" text="%bankImport.button.import"
                    styleClass="button-primary, button-large"
                    onAction="#handleImport"/>
        </HBox>

        <!-- Progress (shown during import) -->
        <VBox fx:id="importProgress" styleClass="import-progress" alignment="CENTER" spacing="12"
              managed="false" visible="false">
            <ProgressIndicator fx:id="progressIndicatorSpinner" prefWidth="48" prefHeight="48"/>
            <Label fx:id="progressLabel" text="%bankImport.progress.importing" styleClass="progress-text"/>
            <ProgressBar fx:id="progressBar" prefWidth="300"/>
        </VBox>

    </VBox>

    </VBox>
    </ScrollPane>

    <!-- Fixed Footer -->
    <HBox styleClass="wizard-footer" alignment="CENTER_RIGHT" spacing="12">
        <padding><Insets top="12" right="30" bottom="12" left="30"/></padding>
        <Button fx:id="cancelBtn" text="%bankImport.button.cancel" styleClass="button-secondary"
                onAction="#handleCancel"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="backBtn" text="%bankImport.button.back" styleClass="button-secondary"
                onAction="#handleBack" visible="false" managed="false"/>
        <Button fx:id="nextBtn" text="%bankImport.button.next" styleClass="button-primary"
                onAction="#handleNext" disable="true"/>
    </HBox>

</VBox>
