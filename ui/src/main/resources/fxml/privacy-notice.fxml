<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!--
    SE-507: Privacy Notice UI
    Full-screen modal dialog for privacy notice acknowledgment.
    Design specification: /aura
    Legal content: /alex (Version 1.0)
-->
<!-- Stylesheets loaded programmatically to avoid JPMS issues -->
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="uk.selfemploy.ui.controller.PrivacyNoticeController"
      styleClass="privacy-notice-container" prefWidth="600" maxHeight="700">

    <!-- Header -->
    <HBox fx:id="headerRow" styleClass="dialog-header" alignment="CENTER_LEFT">
        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
        <Label text="%privacy.header.title" styleClass="dialog-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Settings mode close button (X) - hidden by default -->
        <Button fx:id="headerCloseBtn" text="X" styleClass="close-button"
                onAction="#handleClose" visible="false" managed="false"
                accessibleText="%privacy.header.close.accessible"/>
    </HBox>

    <!-- Content -->
    <VBox styleClass="dialog-content" spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="24" bottom="24" left="24"/></padding>

        <!-- Privacy Header -->
        <VBox styleClass="privacy-header" alignment="CENTER" spacing="12">
            <Label text="🛡" styleClass="privacy-icon"/>
            <Label text="%privacy.hero.title" styleClass="privacy-title"/>
            <HBox alignment="CENTER" spacing="8">
                <Label fx:id="versionLabel" text="%privacy.hero.version" styleClass="privacy-version"/>
                <Label text="|" styleClass="privacy-separator"/>
                <Label fx:id="effectiveDateLabel" text="%privacy.hero.effective"
                       styleClass="privacy-effective-date"/>
            </HBox>
        </VBox>

        <!-- Scrollable Privacy Content -->
        <ScrollPane fx:id="contentScroll" styleClass="privacy-content-scroll"
                    fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
            <VBox fx:id="privacyContent" styleClass="privacy-content" spacing="16">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <!-- Section 1: Who We Are -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section1.title" styleClass="privacy-section-title"/>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section1.p1"/>
                    <Label styleClass="privacy-section-text privacy-important" wrapText="true"
                           text="%privacy.section1.p2"/>
                </VBox>

                <!-- Section 2: Data We Process -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section2.title" styleClass="privacy-section-title"/>

                    <!-- 2.1 Financial and Tax Data -->
                    <Label text="%privacy.section2.sub1.title" styleClass="privacy-subsection-title"/>
                    <VBox styleClass="privacy-list" spacing="4">
                        <Label text="%privacy.section2.sub1.item1"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub1.item2"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub1.item3"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub1.item4"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub1.item5"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub1.item6"
                               styleClass="privacy-list-item" wrapText="true"/>
                    </VBox>
                    <Label styleClass="privacy-section-text privacy-storage" wrapText="true"
                           text="%privacy.section2.sub1.stored"/>
                    <Label styleClass="privacy-section-text privacy-retention" wrapText="true"
                           text="%privacy.section2.sub1.retention"/>

                    <!-- 2.2 Bank Statement Data -->
                    <Label text="%privacy.section2.sub2.title" styleClass="privacy-subsection-title"/>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section2.sub2.intro"/>
                    <VBox styleClass="privacy-list" spacing="4">
                        <Label text="%privacy.section2.sub2.item1"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub2.item2"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub2.item3"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub2.item4"
                               styleClass="privacy-list-item" wrapText="true"/>
                    </VBox>
                    <Label styleClass="privacy-section-text privacy-important" wrapText="true"
                           text="%privacy.section2.sub2.minimisation"/>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section2.sub2.csv"/>

                    <!-- 2.3 HMRC Connection Data -->
                    <Label text="%privacy.section2.sub3.title" styleClass="privacy-subsection-title"/>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section2.sub3.intro"/>
                    <VBox styleClass="privacy-list" spacing="4">
                        <Label text="%privacy.section2.sub3.item1"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub3.item2"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub3.item3"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section2.sub3.item4"
                               styleClass="privacy-list-item" wrapText="true"/>
                    </VBox>
                    <Label styleClass="privacy-section-text privacy-important" wrapText="true"
                           text="%privacy.section2.sub3.why"/>
                </VBox>

                <!-- Section 3: How We Use Your Data -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section3.title" styleClass="privacy-section-title"/>
                    <VBox styleClass="privacy-list" spacing="4">
                        <Label text="%privacy.section3.item1"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section3.item2"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section3.item3"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section3.item4"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section3.item5"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section3.item6"
                               styleClass="privacy-list-item" wrapText="true"/>
                    </VBox>
                </VBox>

                <!-- Section 4: Data Storage and Security -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section4.title" styleClass="privacy-section-title"/>
                    <Label styleClass="privacy-section-text privacy-important" wrapText="true"
                           text="%privacy.section4.p1"/>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section4.p2"/>
                    <VBox styleClass="privacy-list" spacing="4">
                        <Label text="%privacy.section4.item1"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section4.item2"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section4.item3"
                               styleClass="privacy-list-item" wrapText="true"/>
                    </VBox>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section4.p3"/>
                </VBox>

                <!-- Section 5: Data Retention -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section5.title" styleClass="privacy-section-title"/>
                    <VBox styleClass="privacy-list" spacing="4">
                        <Label text="%privacy.section5.item1"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section5.item2"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section5.item3"
                               styleClass="privacy-list-item" wrapText="true"/>
                    </VBox>
                    <Label styleClass="privacy-section-text privacy-important" wrapText="true"
                           text="%privacy.section5.responsibility"/>
                </VBox>

                <!-- Section 6: Your Rights -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section6.title" styleClass="privacy-section-title"/>
                    <VBox styleClass="privacy-list" spacing="4">
                        <Label text="%privacy.section6.item1"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section6.item2"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section6.item3"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section6.item4"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section6.item5"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section6.item6"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.section6.item7"
                               styleClass="privacy-list-item" wrapText="true"/>
                    </VBox>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section6.note"/>
                </VBox>

                <!-- Section 7: HMRC Fraud Prevention -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section7.title" styleClass="privacy-section-title"/>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section7.p1"/>
                    <Label styleClass="privacy-section-text privacy-important" wrapText="true"
                           text="%privacy.section7.p2"/>
                </VBox>

                <!-- Section 8: Changes to This Notice -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section8.title" styleClass="privacy-section-title"/>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section8.p1"/>
                </VBox>

                <!-- Section 9: Contact -->
                <VBox styleClass="privacy-section" spacing="8">
                    <Label text="%privacy.section9.title" styleClass="privacy-section-title"/>
                    <Label styleClass="privacy-section-text" wrapText="true"
                           text="%privacy.section9.p1"/>
                </VBox>

                <!-- Legal Basis Summary -->
                <VBox styleClass="privacy-section privacy-summary" spacing="8">
                    <Label text="%privacy.legalBasis.title" styleClass="privacy-section-title"/>
                    <VBox styleClass="privacy-list" spacing="4">
                        <Label text="%privacy.legalBasis.item1"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.legalBasis.item2"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.legalBasis.item3"
                               styleClass="privacy-list-item" wrapText="true"/>
                        <Label text="%privacy.legalBasis.item4"
                               styleClass="privacy-list-item" wrapText="true"/>
                    </VBox>
                    <Label styleClass="privacy-section-text privacy-compliance" wrapText="true"
                           text="%privacy.legalBasis.compliance"/>
                </VBox>

                <!-- Full Privacy Policy Link -->
                <HBox alignment="CENTER" styleClass="privacy-link-container">
                    <Hyperlink fx:id="fullPolicyLink" text="%privacy.fullPolicyLink"
                               styleClass="privacy-full-link" onAction="#handleOpenFullPolicy"/>
                </HBox>
            </VBox>
        </ScrollPane>

        <!-- Acknowledgment Checkbox (PS11-001: Updated text per /alex legal) -->
        <HBox styleClass="acknowledgment-row" alignment="CENTER_LEFT" spacing="12">
            <CheckBox fx:id="acknowledgeCheckbox" styleClass="legal-checkbox"
                      onAction="#handleAcknowledgeChange"
                      accessibleText="%privacy.checkbox.accessible"/>
            <Label fx:id="acknowledgmentLabel"
                   text="%privacy.acknowledgment.label"
                   styleClass="acknowledgment-label" wrapText="true"
                   labelFor="$acknowledgeCheckbox"/>
        </HBox>
    </VBox>

    <!-- Footer - First Launch Mode (default) -->
    <HBox fx:id="firstLaunchFooter" styleClass="dialog-footer" alignment="CENTER">
        <padding><Insets top="16" right="24" bottom="24" left="24"/></padding>
        <Button fx:id="continueBtn" text="%privacy.button.continue" styleClass="button-primary"
                onAction="#handleContinue" disable="true" prefWidth="200"
                accessibleText="%privacy.button.continue.accessible"/>
    </HBox>

    <!-- Footer - Settings Mode (hidden by default) -->
    <HBox fx:id="settingsFooter" styleClass="dialog-footer, privacy-footer-settings"
          alignment="CENTER" spacing="12" visible="false" managed="false">
        <padding><Insets top="16" right="24" bottom="24" left="24"/></padding>
        <Button fx:id="closeBtn" text="%privacy.button.close" styleClass="button-secondary"
                onAction="#handleClose" prefWidth="100"
                accessibleText="%privacy.button.close.accessible"/>
        <Button fx:id="acknowledgeBtn" text="%privacy.button.acknowledge" styleClass="button-primary"
                onAction="#handleAcknowledge" disable="true" prefWidth="140"
                accessibleText="%privacy.button.acknowledge.accessible"/>
    </HBox>
</VBox>
