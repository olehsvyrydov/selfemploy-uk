<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Stylesheets loaded programmatically to avoid JPMS issues -->
<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="uk.selfemploy.ui.controller.TaxSummaryController"
            styleClass="tax-summary-scroll"
            fitToWidth="true" hbarPolicy="NEVER">

    <VBox fx:id="taxSummaryContainer" styleClass="tax-summary-container" spacing="20">
        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

        <!-- Page Header -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="%taxSummary.title" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="taxYearBadge" text="Tax Year 2025/26" styleClass="tax-year-badge"/>
        </HBox>

        <!-- Submission status banner - only visible after HMRC submission -->
        <HBox fx:id="draftBanner" styleClass="submitted-banner" alignment="CENTER_LEFT" spacing="12"
              managed="false" visible="false">
            <Label text="%taxSummary.submittedBanner" styleClass="submitted-banner-text"/>
        </HBox>

        <!-- No-data empty state (shown when no income or expenses exist for the year) -->
        <VBox fx:id="emptyState" styleClass="empty-state-container"
              alignment="CENTER" spacing="16" managed="false" visible="false">
            <padding><Insets topRightBottomLeft="60"/></padding>
            <Label text="%taxSummary.emptyStateTitle" styleClass="empty-state-title"/>
            <Label styleClass="empty-state-message" wrapText="true" textAlignment="CENTER" maxWidth="420"
                   text="%taxSummary.emptyStateMessage"/>
            <HBox alignment="CENTER" spacing="12">
                <Button text="%taxSummary.addIncomeButton" styleClass="button-success" onAction="#handleGoToIncome"/>
                <Button text="%taxSummary.addExpenseButton" styleClass="button-secondary" onAction="#handleGoToExpenses"/>
            </HBox>
        </VBox>

        <!-- Tax calculation content (hidden when there is no data) -->
        <VBox fx:id="dataContent" spacing="20">

        <!-- Neutral tax summary note -->
        <HBox fx:id="taxDisclaimerBanner" alignment="CENTER_LEFT" spacing="8" managed="true" visible="true"
              style="-fx-padding: 8 16;">
            <Label fx:id="taxDisclaimerText"
                   text="%taxSummary.disclaimer"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;" wrapText="true"/>
        </HBox>

        <!-- Tax At A Glance -->
        <VBox styleClass="tax-glance-card" spacing="20">
            <Label text="%taxSummary.glanceTitle" styleClass="tax-glance-title"/>

            <HBox spacing="20">
                <!-- Net Profit Metric -->
                <VBox styleClass="tax-metric-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8">
                    <Label text="%taxSummary.netProfitLabel" styleClass="tax-metric-label"/>
                    <Label text="(Box 31)" styleClass="tax-metric-box-ref"/>
                    <Label fx:id="netProfitValue" text="£0.00" styleClass="tax-metric-value, profit"/>
                </VBox>

                <!-- Income Tax Metric -->
                <VBox styleClass="tax-metric-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8">
                    <Label text="%taxSummary.incomeTaxLabel" styleClass="tax-metric-label"/>
                    <Label fx:id="incomeTaxValue" text="£0.00" styleClass="tax-metric-value, income-tax"/>
                </VBox>

                <!-- NI Class 4 Metric -->
                <VBox styleClass="tax-metric-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8">
                    <Label text="%taxSummary.niClass4Label" styleClass="tax-metric-label"/>
                    <Label fx:id="niClass4Value" text="£0.00" styleClass="tax-metric-value, ni-class4"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER" styleClass="total-tax-due-container" spacing="8">
                <Label text="%taxSummary.totalTaxDueLabel" styleClass="total-tax-due-label"/>
                <Label fx:id="totalTaxDueValue" text="£0.00" styleClass="total-tax-due-value"/>
            </HBox>
        </VBox>

        <!-- Income Section -->
        <VBox fx:id="incomeSection" styleClass="section-card">
            <HBox styleClass="section-header" alignment="CENTER_LEFT"
                  onMouseClicked="#handleToggleIncomeSection">
                <Label fx:id="incomeToggle" text="[v]" styleClass="section-toggle"/>
                <Label text="%taxSummary.incomeSectionTitle" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="incomeTotalLabel" text="£0.00" styleClass="section-total, income"/>
            </HBox>
            <VBox fx:id="incomeContent" styleClass="section-content" spacing="0">
                <!-- Income line items populated dynamically -->
                <HBox styleClass="line-item" alignment="CENTER_LEFT">
                    <Label text="%taxSummary.totalTurnoverLabel" styleClass="line-item-label"/>
                    <Label text="(Box 15)" styleClass="line-item-box"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="turnoverLineValue" text="£0.00" styleClass="line-item-value"/>
                </HBox>
                <HBox styleClass="line-item" alignment="CENTER_LEFT">
                    <Label text="%taxSummary.otherIncomeLabel" styleClass="line-item-label"/>
                    <Label text="(Box 16)" styleClass="line-item-box"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="otherIncomeLineValue" text="£0.00" styleClass="line-item-value"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Expenses Section -->
        <VBox fx:id="expensesSection" styleClass="section-card">
            <HBox styleClass="section-header" alignment="CENTER_LEFT"
                  onMouseClicked="#handleToggleExpensesSection">
                <Label fx:id="expensesToggle" text="[v]" styleClass="section-toggle"/>
                <Label text="%taxSummary.allowableExpensesTitle" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="expensesTotalLabel" text="£0.00" styleClass="section-total, expenses"/>
            </HBox>
            <VBox fx:id="expensesContent" styleClass="section-content" spacing="0">
                <!-- Expense line items populated dynamically by controller -->
            </VBox>
        </VBox>

        <!-- Profit Calculation Section -->
        <VBox styleClass="section-card">
            <HBox styleClass="section-header" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="fas-equals" iconSize="14" styleClass="section-toggle"/>
                <Label text="%taxSummary.profitCalculationTitle" styleClass="section-title"/>
            </HBox>
            <VBox styleClass="section-content" spacing="0">
                <HBox styleClass="calc-row" alignment="CENTER_LEFT">
                    <Label text="%taxSummary.turnoverLabel" styleClass="calc-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="turnoverCalcValue" text="£0.00" styleClass="calc-value"/>
                </HBox>
                <HBox styleClass="calc-row" alignment="CENTER_LEFT">
                    <Label text="%taxSummary.lessAllowableExpenses" styleClass="calc-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="expensesCalcValue" text="-£0.00" styleClass="calc-value, line-item-value, negative"/>
                </HBox>
                <Separator styleClass="calc-divider"/>
                <HBox styleClass="calc-row" alignment="CENTER_LEFT">
                    <Label text="%taxSummary.netProfitBox31" styleClass="calc-label" style="-fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="netProfitCalcValue" text="£0.00" styleClass="calc-result"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Income Tax Section -->
        <VBox fx:id="incomeTaxSection" styleClass="section-card">
            <HBox styleClass="section-header" alignment="CENTER_LEFT"
                  onMouseClicked="#handleToggleIncomeTaxSection">
                <Label fx:id="incomeTaxToggle" text="[v]" styleClass="section-toggle"/>
                <Label text="%taxSummary.incomeTaxSectionTitle" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="incomeTaxTotalLabel" text="£0.00" styleClass="section-total, tax"/>
            </HBox>
            <VBox fx:id="incomeTaxContent" styleClass="section-content" spacing="0">
                <!-- Tax band rows populated dynamically by controller -->
            </VBox>
        </VBox>

        <!-- NI Class 4 Section -->
        <VBox fx:id="niSection" styleClass="section-card">
            <HBox styleClass="section-header" alignment="CENTER_LEFT"
                  onMouseClicked="#handleToggleNISection">
                <Label fx:id="niToggle" text="[v]" styleClass="section-toggle"/>
                <Label text="%taxSummary.niSectionTitle" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="niTotalLabel" text="£0.00" styleClass="section-total, ni"/>
            </HBox>
            <VBox fx:id="niContent" styleClass="section-content" spacing="0">
                <!-- NI rate rows populated dynamically by controller -->
            </VBox>
        </VBox>

        <!-- Class 2 NI Credit Clarification (SE-810) -->
        <VBox fx:id="class2NiCard" styleClass="class2-ni-card" spacing="12"
              managed="false" visible="false">

            <!-- Header -->
            <HBox styleClass="class2-ni-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="class2-ni-icon">
                    <FontIcon iconLiteral="fas-info-circle" iconSize="16"/>
                </StackPane>
                <Label fx:id="class2Title" text="Class 2 NI Credits" styleClass="class2-ni-title"/>
                <Label fx:id="voluntaryBadge" text="%taxSummary.voluntaryBadge" styleClass="voluntary-badge"
                       managed="false" visible="false"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="class2HelpBtn" text="?" styleClass="help-icon-btn"
                        onAction="#handleShowClass2Help"/>
            </HBox>

            <!-- Body Text -->
            <Label fx:id="class2BodyText" styleClass="class2-ni-body" wrapText="true"/>

            <!-- Rates Box -->
            <VBox styleClass="class2-rates-box" spacing="8">
                <HBox styleClass="class2-rates-row" alignment="CENTER_LEFT">
                    <Label fx:id="class2WeeklyLabel" text="Weekly rate (2025/26):" styleClass="class2-rates-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="class2WeeklyValue" text="£3.45" styleClass="class2-rates-value"/>
                </HBox>
                <HBox styleClass="class2-rates-row" alignment="CENTER_LEFT">
                    <Label text="%taxSummary.class2AnnualLabel" styleClass="class2-rates-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="class2AnnualValue" text="£179.40" styleClass="class2-rates-value"/>
                </HBox>
            </VBox>

            <!-- Pension Insight -->
            <VBox styleClass="pension-insight-box" spacing="4">
                <HBox styleClass="pension-insight-header" alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fas-star" iconSize="14" styleClass="pension-insight-icon"/>
                    <Label text="%taxSummary.pensionInsightTitle" styleClass="pension-insight-title"/>
                </HBox>
                <Label fx:id="pensionInsightText" styleClass="pension-insight-text" wrapText="true"/>
            </VBox>

            <!-- External Link -->
            <Hyperlink fx:id="statePensionLink"
                       text="%taxSummary.statePensionLink"
                       styleClass="class2-external-link"
                       onAction="#handleStatePensionLink"/>

        </VBox>

        <!-- Payments on Account Section (conditional) -->
        <VBox fx:id="poaSection" styleClass="section-card" managed="false" visible="false">
            <HBox styleClass="section-header" alignment="CENTER_LEFT"
                  onMouseClicked="#handleTogglePOASection">
                <Label fx:id="poaToggle" text="[v]" styleClass="section-toggle"/>
                <Label fx:id="poaSectionTitle" text="PAYMENTS ON ACCOUNT (2026/27)" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="poaTotalLabel" text="£0.00" styleClass="section-total, tax"/>
            </HBox>
            <VBox fx:id="poaContent" styleClass="section-content" spacing="8">
                <HBox styleClass="line-item" alignment="CENTER_LEFT">
                    <Label fx:id="poaFirstLabel" text="First Payment (31 January 2027)" styleClass="line-item-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="poaFirstPayment" text="£0.00" styleClass="line-item-value"/>
                </HBox>
                <HBox styleClass="line-item" alignment="CENTER_LEFT">
                    <Label fx:id="poaSecondLabel" text="Second Payment (31 July 2027)" styleClass="line-item-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="poaSecondPayment" text="£0.00" styleClass="line-item-value"/>
                </HBox>
                <Hyperlink fx:id="poaInfoLink" text="%taxSummary.poaInfoLink"
                           styleClass="poa-info-link" onAction="#handleShowPOAInfo"/>
            </VBox>
        </VBox>

        <!-- Total Amount Due Card -->
        <VBox styleClass="total-due-card" spacing="16" alignment="CENTER">
            <Label text="%taxSummary.totalAmountDue" styleClass="total-due-title"/>

            <VBox spacing="8" alignment="CENTER">
                <HBox alignment="CENTER" spacing="8">
                    <Label fx:id="taxYearDueLabel" text="Tax Year 2025/26:" styleClass="total-due-breakdown-label"/>
                    <Label fx:id="taxYearDueValue" text="£0.00" styleClass="total-due-breakdown-value"/>
                </HBox>
                <HBox fx:id="poaDueRow" alignment="CENTER" spacing="8" managed="false" visible="false">
                    <Label text="%taxSummary.paymentsOnAccountLabel" styleClass="total-due-breakdown-label"/>
                    <Label fx:id="poaDueValue" text="£0.00" styleClass="total-due-breakdown-value"/>
                </HBox>
                <Separator/>
                <Label fx:id="grandTotalValue" text="£0.00" styleClass="total-due-amount"/>
            </VBox>

            <Label fx:id="dueDateLabel" text="Due by 31 January 2027" styleClass="total-due-date"/>
        </VBox>

        <!-- Action Bar -->
        <HBox styleClass="tax-action-bar" alignment="CENTER_RIGHT" spacing="16">
            <Button fx:id="exportPdfBtn" text="%taxSummary.exportPdfButton" styleClass="button-pdf"
                    onAction="#handleExportPDF"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="submitBtn" text="%taxSummary.submitButton" styleClass="button-submit"
                    onAction="#handleSubmitToHMRC" disable="true">
                <tooltip>
                    <Tooltip text="%taxSummary.submitTooltip"/>
                </tooltip>
            </Button>
        </HBox>

        </VBox>
        <!-- /dataContent -->

    </VBox>
</ScrollPane>
