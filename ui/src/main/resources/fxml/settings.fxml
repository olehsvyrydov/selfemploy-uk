<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    Settings Page - User preferences and configuration
    Provides access to:
    - Profile settings (UTR)
    - Legal documents (Terms, Privacy)
    - Data management (Export/Import)
    - Application info
-->
<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="uk.selfemploy.ui.controller.SettingsController"
            styleClass="settings-scroll" fitToWidth="true" hbarPolicy="NEVER">

    <VBox styleClass="settings-container" spacing="24">
        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

        <!-- Page Header -->
        <VBox spacing="8">
            <Label text="%settings.page.title" styleClass="page-title"/>
            <Label text="%settings.page.subtitle" styleClass="page-subtitle"/>
        </VBox>

        <!-- Profile Section -->
        <VBox styleClass="settings-section, settings-section-profile" spacing="16">
            <Label text="%settings.profile.title" styleClass="section-title"/>

            <!-- Display Name Setting (optional, personalization) -->
            <VBox styleClass="settings-card, settings-card-profile" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <FontIcon iconLiteral="fas-user" iconSize="20" styleClass="settings-icon"/>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="%settings.displayName.label" styleClass="settings-label"/>
                        <Label fx:id="displayNameLabel" text="%settings.value.notSet" styleClass="settings-value"/>
                    </VBox>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="displayNameField"
                               promptText="%settings.displayName.prompt"
                               styleClass="utr-field" HBox.hgrow="ALWAYS"
                               accessibleText="%settings.displayName.accessible"/>
                    <Button fx:id="saveDisplayNameButton" text="%settings.button.save" styleClass="button-secondary" onAction="#handleSaveDisplayName"/>
                </HBox>
                <Label text="%settings.displayName.hint"
                       styleClass="settings-hint" wrapText="true"/>
            </VBox>

            <!-- UTR Setting -->
            <VBox styleClass="settings-card, settings-card-profile" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <FontIcon iconLiteral="fas-clipboard" iconSize="20" styleClass="settings-icon"/>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="%settings.utr.label" styleClass="settings-label"/>
                        <Label fx:id="utrLabel" text="%settings.value.notSet" styleClass="settings-value"/>
                    </VBox>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="utrField" promptText="%settings.utr.prompt"
                               styleClass="utr-field" HBox.hgrow="ALWAYS"
                               accessibleText="%settings.utr.accessible"/>
                    <Button fx:id="saveUtrButton" text="%settings.button.save" styleClass="button-secondary" onAction="#handleSaveUtr"/>
                </HBox>
                <Label text="%settings.utr.hint"
                       styleClass="settings-hint" wrapText="true"/>
            </VBox>

            <!-- NINO Setting -->
            <VBox styleClass="settings-card, settings-card-profile" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <FontIcon iconLiteral="fas-id-card" iconSize="20" styleClass="settings-icon"/>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="%settings.nino.label" styleClass="settings-label"/>
                        <Label fx:id="ninoLabel" text="%settings.value.notSet" styleClass="settings-value"/>
                    </VBox>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="ninoField" promptText="%settings.nino.prompt"
                               styleClass="utr-field" HBox.hgrow="ALWAYS"
                               accessibleText="%settings.nino.accessible"/>
                    <Button fx:id="saveNinoButton" text="%settings.button.save" styleClass="button-secondary" onAction="#handleSaveNino"/>
                </HBox>
                <Label text="%settings.nino.hint"
                       styleClass="settings-hint" wrapText="true"/>
            </VBox>
        </VBox>

        <!-- HMRC API Credentials Section (BYO Model) -->
        <VBox styleClass="settings-section, settings-section-hmrc" spacing="16">
            <Label text="%settings.hmrcCredentials.title" styleClass="section-title"/>

            <VBox styleClass="settings-card, settings-card-hmrc" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <FontIcon iconLiteral="fas-key" iconSize="20" styleClass="settings-icon"/>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="%settings.hmrcCredentials.label" styleClass="settings-label"/>
                        <Label fx:id="hmrcCredentialsStatusLabel" text="%settings.hmrcCredentials.notConfigured" styleClass="settings-value"/>
                    </VBox>
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="%settings.hmrcCredentials.hint"
                           styleClass="settings-hint" wrapText="true" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="hmrcRegistrationHelpButton" text="%settings.hmrcCredentials.help" styleClass="button-secondary" onAction="#handleShowRegistrationHelp"/>
                </HBox>

                <!-- Redirect URI (read-only, shown first as users need it during registration) -->
                <VBox spacing="4">
                    <Label text="%settings.hmrcCredentials.redirectUri.label" styleClass="settings-label"
                           labelFor="$hmrcRedirectUriField"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="hmrcRedirectUriField"
                                   text="http://localhost:8088/oauth/callback"
                                   styleClass="utr-field" editable="false" HBox.hgrow="ALWAYS"
                                   accessibleText="%settings.hmrcCredentials.redirectUri.accessible"/>
                        <Button fx:id="copyRedirectUriButton" text="%settings.button.copy" styleClass="button-secondary" onAction="#handleCopyRedirectUri"/>
                    </HBox>
                </VBox>

                <!-- Client ID -->
                <VBox spacing="4">
                    <Label text="%settings.hmrcCredentials.clientId.label" styleClass="settings-label"
                           labelFor="$hmrcClientIdField"/>
                    <TextField fx:id="hmrcClientIdField"
                               promptText="%settings.hmrcCredentials.clientId.prompt"
                               styleClass="utr-field"
                               accessibleText="%settings.hmrcCredentials.clientId.accessible"/>
                </VBox>

                <!-- Client Secret -->
                <VBox spacing="4">
                    <Label text="%settings.hmrcCredentials.clientSecret.label" styleClass="settings-label"
                           labelFor="$hmrcClientSecretField"/>
                    <PasswordField fx:id="hmrcClientSecretField"
                                   promptText="%settings.hmrcCredentials.clientSecret.prompt"
                                   styleClass="utr-field"
                                   accessibleText="%settings.hmrcCredentials.clientSecret.accessible"/>
                </VBox>

                <!-- Action Buttons -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button fx:id="saveCredentialsButton" text="%settings.hmrcCredentials.save" styleClass="button-primary" onAction="#handleSaveHmrcCredentials"/>
                    <Button fx:id="clearCredentialsButton" text="%settings.button.clear" styleClass="button-secondary" onAction="#handleClearHmrcCredentials"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- HMRC Connection Setup Section -->
        <VBox styleClass="settings-section, settings-section-hmrc" spacing="16">
            <Label text="%settings.hmrcConnection.title" styleClass="section-title"/>

            <VBox styleClass="settings-card, settings-card-hmrc" spacing="12">
                <!-- Status Display -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <FontIcon fx:id="hmrcStatusIcon" iconLiteral="fas-link" iconSize="20" styleClass="settings-icon"/>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="%settings.hmrcConnection.statusLabel" styleClass="settings-label"/>
                        <Label fx:id="hmrcConnectionStatusLabel" text="%settings.hmrcConnection.notSetUp" styleClass="settings-value"/>
                    </VBox>
                </HBox>

                <!-- Environment Toggle -->
                <VBox spacing="4">
                    <Label text="%settings.hmrcConnection.environment.label" styleClass="settings-label"
                           labelFor="$hmrcEnvironmentCombo"/>
                    <ComboBox fx:id="hmrcEnvironmentCombo"
                              styleClass="utr-field" maxWidth="250"
                              accessibleText="%settings.hmrcConnection.environment.accessible"/>
                    <Label fx:id="hmrcEnvironmentHint"
                           text="%settings.hmrcConnection.environment.hint"
                           styleClass="settings-hint" wrapText="true"/>
                </VBox>

                <!-- Setup Instructions -->
                <Label fx:id="hmrcSetupInstructions"
                       text="%settings.hmrcConnection.instructions"
                       styleClass="settings-hint" wrapText="true"/>

                <!-- Action Buttons -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button fx:id="hmrcSetupButton" text="%settings.hmrcConnection.connect" styleClass="button-primary" onAction="#handleHmrcSetup"/>
                    <Button fx:id="hmrcDisconnectButton" text="%settings.hmrcConnection.disconnect" styleClass="button-secondary" onAction="#handleHmrcDisconnect" visible="false" managed="false"/>
                </HBox>

                <!-- Setup Checklist (shows progress) -->
                <VBox fx:id="hmrcSetupChecklist" spacing="4" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontIcon fx:id="checkNino" iconLiteral="fas-circle" iconSize="12"/>
                        <Label text="%settings.hmrcConnection.check.nino" styleClass="settings-hint"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontIcon fx:id="checkOAuth" iconLiteral="fas-circle" iconSize="12"/>
                        <Label text="%settings.hmrcConnection.check.oauth" styleClass="settings-hint"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontIcon fx:id="checkProfile" iconLiteral="fas-circle" iconSize="12"/>
                        <Label text="%settings.hmrcConnection.check.profile" styleClass="settings-hint"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>

        <!-- Legal Section -->
        <VBox styleClass="settings-section, settings-section-legal" spacing="16">
            <Label text="%settings.legal.title" styleClass="section-title"/>

            <!-- Terms of Service -->
            <HBox styleClass="settings-card-row, settings-card-legal" alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconLiteral="fas-file-alt" iconSize="20" styleClass="settings-icon"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%settings.legal.terms.label" styleClass="settings-label"/>
                    <Label text="%settings.legal.terms.description" styleClass="settings-description"/>
                </VBox>
                <Button fx:id="termsButton" text="%settings.button.view" styleClass="button-secondary" onAction="#handleShowTerms"/>
            </HBox>

            <!-- Privacy Notice -->
            <HBox styleClass="settings-card-row, settings-card-legal" alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconLiteral="fas-shield-alt" iconSize="20" styleClass="settings-icon"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%settings.legal.privacy.label" styleClass="settings-label"/>
                    <Label text="%settings.legal.privacy.description" styleClass="settings-description"/>
                </VBox>
                <Button fx:id="privacyButton" text="%settings.button.view" styleClass="button-secondary" onAction="#handleShowPrivacy"/>
            </HBox>

            <!-- Disclaimer removed per SLFEMPUK-22: ToS covers liability -->
        </VBox>

        <!-- Data Management Section -->
        <VBox styleClass="settings-section, settings-section-data" spacing="16">
            <Label text="%settings.data.title" styleClass="section-title"/>

            <!-- Back up data -->
            <HBox styleClass="settings-card-row, settings-card-data" alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconLiteral="fas-upload" iconSize="20" styleClass="settings-icon"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%settings.data.backup.label" styleClass="settings-label"/>
                    <Label text="%settings.data.backup.description" styleClass="settings-description"/>
                </VBox>
                <Button fx:id="exportButton" text="%settings.data.backup.button" styleClass="button-secondary" onAction="#handleExportData"/>
            </HBox>

            <!-- Restore from backup -->
            <HBox styleClass="settings-card-row, settings-card-data" alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconLiteral="fas-download" iconSize="20" styleClass="settings-icon"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%settings.data.restore.label" styleClass="settings-label"/>
                    <Label text="%settings.data.restore.description" styleClass="settings-description"/>
                </VBox>
                <Button fx:id="importButton" text="%settings.data.restore.button" styleClass="button-secondary" onAction="#handleImportData"/>
            </HBox>
        </VBox>

        <!-- About Section -->
        <VBox styleClass="settings-section" spacing="16">
            <Label text="%settings.about.title" styleClass="section-title"/>

            <VBox styleClass="settings-card" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <FontIcon iconLiteral="fas-info-circle" iconSize="20" styleClass="settings-icon"/>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="%settings.about.appName" styleClass="settings-label"/>
                        <Label fx:id="versionLabel" text="%settings.about.versionLoading" styleClass="settings-value"/>
                    </VBox>
                </HBox>
                <Label fx:id="buildDateLabel" text="" styleClass="settings-hint"/>
                <Label fx:id="licenseLabel" text="" styleClass="settings-hint"/>
                <Label fx:id="githubLabel" text="" styleClass="settings-hint" style="-fx-text-fill: #3b82f6; -fx-cursor: hand;"
                       accessibleText="%settings.about.github.accessible"/>
                <CheckBox fx:id="updateCheckToggle" text="%settings.about.updateCheckToggle" styleClass="settings-hint"/>
                <Label fx:id="updateStatusLabel" text="" visible="false" managed="false" styleClass="settings-hint" wrapText="true"/>
                <Label fx:id="updateGuidanceLabel" text="" visible="false" managed="false" styleClass="settings-hint" wrapText="true"
                       style="-fx-text-fill: #3b82f6; -fx-cursor: hand;" accessibleText="%settings.about.updateLink.accessible"/>
            </VBox>
        </VBox>

        <!-- Footer disclaimer removed per SLFEMPUK-19: Legal section covers this -->

    </VBox>
</ScrollPane>
