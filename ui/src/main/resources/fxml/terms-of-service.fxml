<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!--
    SE-508: Terms of Service UI
    Full-screen modal dialog for Terms of Service acceptance (Version 1.0).

    Key Features:
    - Scroll tracking: Accept button only enabled after scrolling to bottom
    - Table of Contents sidebar for quick navigation
    - Progress bar showing scroll completion
    - Decline flow with confirmation dialog
-->
<!-- Stylesheets loaded programmatically to avoid JPMS issues -->
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="uk.selfemploy.ui.controller.TermsOfServiceController"
      styleClass="tos-container" prefWidth="900">

    <!-- Header -->
    <HBox styleClass="dialog-header" alignment="CENTER_LEFT">
        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
        <Label text="%terms.header.title" styleClass="dialog-title"/>
    </HBox>

    <!-- Content -->
    <VBox styleClass="dialog-content" spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>

        <!-- ToS Header -->
        <VBox styleClass="tos-header" alignment="CENTER" spacing="4" maxHeight="110">
            <padding><Insets top="8" right="0" bottom="8" left="0"/></padding>
            <Label text="§" styleClass="tos-icon"/>
            <Label text="%terms.hero.title" styleClass="tos-title"/>
            <HBox alignment="CENTER" spacing="8">
                <Label fx:id="versionLabel" text="%terms.hero.version" styleClass="tos-version"/>
                <Label text="|" styleClass="tos-separator"/>
                <Label fx:id="lastUpdatedLabel" text="%terms.hero.lastUpdated"
                       styleClass="tos-updated-date"/>
            </HBox>
        </VBox>

        <!-- Main Content Area with ToC Sidebar -->
        <HBox styleClass="tos-main-content" spacing="16" VBox.vgrow="ALWAYS">

            <!-- Table of Contents Sidebar -->
            <VBox fx:id="tocSidebar" styleClass="tos-toc" spacing="4" minWidth="200" maxWidth="200" minHeight="0">
                <Label text="%terms.toc.header" styleClass="toc-header"/>
                <Separator/>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" minHeight="0" VBox.vgrow="ALWAYS"
                            styleClass="toc-scroll">
                <VBox fx:id="tocLinks" styleClass="toc-links" spacing="2">
                    <Hyperlink text="%terms.toc.section1" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section1"/>
                    <Hyperlink text="%terms.toc.section2" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section2"/>
                    <Hyperlink text="%terms.toc.section3" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section3"/>
                    <Hyperlink text="%terms.toc.section4" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section4"/>
                    <Hyperlink text="%terms.toc.section4a" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section4a"/>
                    <Hyperlink text="%terms.toc.section5" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section5"/>
                    <Hyperlink text="%terms.toc.section6" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section6"/>
                    <Hyperlink text="%terms.toc.section7" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section7"/>
                    <Hyperlink text="%terms.toc.section8" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section8"/>
                    <Hyperlink text="%terms.toc.section9" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section9"/>
                    <Hyperlink text="%terms.toc.section10" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section10"/>
                    <Hyperlink text="%terms.toc.section11" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section11"/>
                    <Hyperlink text="%terms.toc.section12" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section12"/>
                    <Hyperlink text="%terms.toc.section13" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section13"/>
                    <Hyperlink text="%terms.toc.section14" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section14"/>
                    <Hyperlink text="%terms.toc.section15" styleClass="toc-link"
                               onAction="#scrollToSection" userData="section15"/>
                </VBox>
                </ScrollPane>
            </VBox>

            <!-- Scrollable ToS Content -->
            <ScrollPane fx:id="contentScroll" styleClass="tos-content-scroll"
                        fitToWidth="true" hbarPolicy="NEVER" HBox.hgrow="ALWAYS"
                        minHeight="120">
                <VBox fx:id="tosContent" styleClass="tos-content" spacing="24">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

                    <!-- Important Header Notice -->
                    <VBox styleClass="tos-important-notice" spacing="8">
                        <Label styleClass="tos-section-text tos-important-header" wrapText="true"
                               text="%terms.important.header"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.important.intro"/>
                    </VBox>

                    <!-- Section 1: Acceptance of Terms -->
                    <VBox fx:id="section1" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section1.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section1.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section1.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section1.p3"/>
                    </VBox>

                    <!-- Section 2: Nature of the Software -->
                    <VBox fx:id="section2" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section2.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section2.p1"/>
                        <Label styleClass="tos-section-text tos-important" wrapText="true"
                               text="%terms.section2.p2"/>
                    </VBox>

                    <!-- Section 3: No Professional Advice - CRITICAL -->
                    <VBox fx:id="section3" styleClass="tos-section" spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="%terms.section3.title" styleClass="tos-section-title"/>
                            <Label text="%terms.section3.badge" styleClass="tos-important-badge"/>
                        </HBox>
                        <VBox styleClass="tos-highlight-box" spacing="8">
                            <Label styleClass="tos-highlight-text" wrapText="true"
                                   text="%terms.section3.p1"/>
                            <Label styleClass="tos-highlight-text" wrapText="true"
                                   text="%terms.section3.p2"/>
                            <Label styleClass="tos-highlight-text" wrapText="true"
                                   text="%terms.section3.p3"/>
                        </VBox>
                        <Label styleClass="tos-section-text tos-important" wrapText="true"
                               text="%terms.section3.p4"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section3.p5"/>
                    </VBox>

                    <!-- Section 4: Your Responsibilities -->
                    <VBox fx:id="section4" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section4.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text tos-bold" wrapText="true"
                               text="%terms.section4.p1"/>
                        <Label styleClass="tos-section-text tos-bold" wrapText="true"
                               text="%terms.section4.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section4.p3"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section4.p4"/>
                    </VBox>

                    <!-- Section 4A: Bank Statement Import -->
                    <VBox fx:id="section4a" styleClass="tos-section" spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="%terms.section4a.title" styleClass="tos-section-title"/>
                        </HBox>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section4a.p1"/>
                        <Label styleClass="tos-section-text tos-bold" wrapText="true"
                               text="%terms.section4a.p2"/>
                        <VBox styleClass="tos-highlight-box" spacing="8">
                            <Label styleClass="tos-highlight-text" wrapText="true"
                                   text="%terms.section4a.p3"/>
                        </VBox>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section4a.p4"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section4a.p5"/>
                        <Label styleClass="tos-section-text tos-important" wrapText="true"
                               text="%terms.section4a.p6"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section4a.p7"/>
                    </VBox>

                    <!-- Section 5: HMRC Integration -->
                    <VBox fx:id="section5" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section5.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section5.p1"/>
                        <Label styleClass="tos-section-text tos-important" wrapText="true"
                               text="%terms.section5.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section5.p3"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section5.p4"/>
                    </VBox>

                    <!-- Section 6: Open Source Licence -->
                    <VBox fx:id="section6" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section6.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section6.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section6.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section6.p3"/>
                    </VBox>

                    <!-- Section 7: Limitation of Liability -->
                    <VBox fx:id="section7" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section7.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text tos-bold" wrapText="true"
                               text="%terms.section7.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section7.p1a"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section7.p1b"/>
                        <Label styleClass="tos-section-text tos-bold" wrapText="true"
                               text="%terms.section7.p2"/>
                        <VBox styleClass="tos-list" spacing="4">
                            <Label text="%terms.section7.item1"
                                   styleClass="tos-list-item" wrapText="true"/>
                            <Label text="%terms.section7.item2"
                                   styleClass="tos-list-item" wrapText="true"/>
                            <Label text="%terms.section7.item3"
                                   styleClass="tos-list-item" wrapText="true"/>
                            <Label text="%terms.section7.item4"
                                   styleClass="tos-list-item" wrapText="true"/>
                            <Label text="%terms.section7.item5"
                                   styleClass="tos-list-item" wrapText="true"/>
                        </VBox>
                        <Label styleClass="tos-section-text tos-bold" wrapText="true"
                               text="%terms.section7.p3"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section7.p4"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section7.p5"/>
                    </VBox>

                    <!-- Section 8: Indemnification -->
                    <VBox fx:id="section8" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section8.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section8.p1"/>
                    </VBox>

                    <!-- Section 9: Data and Privacy -->
                    <VBox fx:id="section9" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section9.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section9.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section9.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section9.p3"/>
                    </VBox>

                    <!-- Section 10: Updates and Changes -->
                    <VBox fx:id="section10" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section10.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section10.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section10.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section10.p3"/>
                    </VBox>

                    <!-- Section 11: Termination -->
                    <VBox fx:id="section11" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section11.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section11.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section11.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section11.p3"/>
                    </VBox>

                    <!-- Section 12: Support -->
                    <VBox fx:id="section12" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section12.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section12.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section12.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section12.p3"/>
                    </VBox>

                    <!-- Section 13: Governing Law and Jurisdiction -->
                    <VBox fx:id="section13" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section13.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section13.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section13.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section13.p3"/>
                    </VBox>

                    <!-- Section 14: General Provisions -->
                    <VBox fx:id="section14" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section14.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section14.p1"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section14.p2"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section14.p3"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section14.p4"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section14.p5"/>
                    </VBox>

                    <!-- Contact Information -->
                    <VBox fx:id="section15" styleClass="tos-section" spacing="8">
                        <Label text="%terms.section15.title" styleClass="tos-section-title"/>
                        <Label styleClass="tos-section-text" wrapText="true"
                               text="%terms.section15.p1"/>
                    </VBox>

                    <!-- Final Declaration -->
                    <VBox styleClass="tos-final-declaration" spacing="8">
                        <Label styleClass="tos-section-text tos-bold" wrapText="true"
                               text="%terms.finalDeclaration"/>
                    </VBox>

                    <!-- Compliance Footer -->
                    <VBox styleClass="tos-compliance-footer" spacing="4">
                        <Label styleClass="tos-compliance-text" wrapText="true"
                               text="%terms.compliance.text"/>
                        <Label styleClass="tos-compliance-text" wrapText="true"
                               text="%terms.compliance.version"/>
                    </VBox>

                    <!-- End Marker (for scroll detection) -->
                    <VBox fx:id="endMarker" styleClass="tos-end-marker" alignment="CENTER">
                        <Label text="%terms.endMarker" styleClass="tos-end-text"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </HBox>

        <!-- Scroll Progress Section -->
        <VBox styleClass="scroll-progress-section" spacing="8" alignment="CENTER">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <ProgressBar fx:id="scrollProgress" progress="0"
                             styleClass="scroll-progress-bar" HBox.hgrow="ALWAYS"/>
                <Label fx:id="scrollPercentLabel" text="0%" styleClass="scroll-percent"/>
            </HBox>
            <Label fx:id="scrollHint" text="%terms.scrollHint"
                   styleClass="scroll-hint"/>
        </VBox>
    </VBox>

    <!-- Footer -->
    <HBox styleClass="dialog-footer, tos-footer" alignment="CENTER_RIGHT" spacing="12">
        <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
        <Button fx:id="printBtn" text="%terms.button.print" styleClass="button-secondary"
                onAction="#handlePrint"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="declineBtn" text="%terms.button.decline" styleClass="button-secondary"
                onAction="#handleDecline"/>
        <Button fx:id="acceptBtn" text="%terms.button.accept" styleClass="button-success"
                onAction="#handleAccept" disable="true"/>
        <Button fx:id="closeBtn" text="%terms.button.close" styleClass="button-success"
                onAction="#handleClose"/>
    </HBox>
</VBox>
