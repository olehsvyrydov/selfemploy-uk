<?xml version="1.0" encoding="UTF-8"?>
<!--
    Bean-archive marker for the server module, so a consuming Quarkus application discovers the
    CDI beans in this jar. Quarkus ArC ignores the discovery mode and always uses annotated
    discovery, so every bean in this module carries a bean-defining annotation.
-->
<beans xmlns="https://jakarta.ee/xml/ns/jakartaee"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd"
       version="4.0"
       bean-discovery-mode="annotated">
</beans>
