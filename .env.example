# =============================================================================
# UK Self-Employment Manager - Environment Configuration
# =============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to `.env` in the project root: cp .env.example .env
# 2. Replace the placeholder values with your actual credentials
# 3. NEVER commit the .env file to version control
#
# To get HMRC credentials:
# 1. Register at https://developer.service.hmrc.gov.uk/developer/registration
# 2. Create an application at https://developer.service.hmrc.gov.uk/developer/applications
# 3. Subscribe to the required APIs (Self Assessment MTD, etc.)
# 4. Copy your Client ID and Client Secret from the application page
#
# =============================================================================

# -----------------------------------------------------------------------------
# HMRC API Credentials (REQUIRED)
# -----------------------------------------------------------------------------
# These are obtained from your HMRC Developer Hub application.
# WARNING: Keep these secret! Never share or commit them.

# Your HMRC application's Client ID (public identifier)
HMRC_CLIENT_ID=your_client_id_here

# Your HMRC application's Client Secret (keep this secret!)
HMRC_CLIENT_SECRET=your_client_secret_here

# -----------------------------------------------------------------------------
# HMRC environment (Sandbox vs Production)
# -----------------------------------------------------------------------------
# The environment is chosen inside the app, in Settings -> HMRC -> Environment
# (Sandbox for testing, Production once HMRC has approved your application). The
# app uses HMRC's official URLs for the selected environment.
#
# For security, the HMRC API URLs are NOT configurable from this file: a .env
# override of the token URL could send your Client Secret to another host, so
# only the keys documented here are read from .env. Switch to Production with
# the Settings environment selector.

# -----------------------------------------------------------------------------
# OAuth Configuration (Optional)
# -----------------------------------------------------------------------------
# Local callback server settings for OAuth flow.
# Change only if port 8088 conflicts with another application.

# Port for the local OAuth callback server (default: 8088)
# HMRC_CALLBACK_PORT=8088

# OAuth scopes required for MTD APIs (default: read and write self-assessment)
# HMRC_SCOPES=read:self-assessment,write:self-assessment

# -----------------------------------------------------------------------------
# Database Configuration (Optional)
# -----------------------------------------------------------------------------
# By default, the database is stored in ~/.selfemploy/data with AES encryption.
# Only modify if you need a custom location.

# Custom database path (default: ${user.home}/.selfemploy/data)
# DB_PATH=${user.home}/.selfemploy/data

# Database password for H2 encryption (default: selfemploy)
# WARNING: Changing this after data exists will make existing data inaccessible!
# DB_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# Application Settings (Optional)
# -----------------------------------------------------------------------------

# Log level for application logs (default: INFO)
# Options: TRACE, DEBUG, INFO, WARN, ERROR
# LOG_LEVEL=INFO

# Enable debug logging for HMRC API calls (default: false)
# HMRC_DEBUG=false

# =============================================================================
# SECURITY REMINDERS
# =============================================================================
#
# 1. NEVER commit the .env file to Git
# 2. NEVER share your Client Secret with anyone
# 3. Use Sandbox credentials for development and testing
# 4. Only switch to Production after HMRC approval
# 5. If credentials are compromised, regenerate them immediately on Developer Hub
#
# For more information, see SECURITY.md
# =============================================================================
